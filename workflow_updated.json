      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3000/scrape",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"url\": \"https://www.gumtree.com/flats-houses/property-to-rent/uk/england?sort=relevance&search_category=property-to-rent&seller_type=private\",\n  \"pages\": 5,\n  \"retries\": 3,\n  \"proxies\": [\n    \"http://username:pass@proxy.example.com:8080\"\n  ]\n}",
        "options": {}
      },
      "id": "28d13666-287a-4f32-b49c-eec1dc0dec4e",
      "name": "Start Local Scrape",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        448,
        0
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Get the API response\nconst scrapeResult = $input.item.json; // Assuming the node returns the JSON as a single item\nconst gumtreeData = (scrapeResult?.data || []).map(item => ({ ...item, source: 'Gumtree' }));\n\n// Existing IDs from your sheet node (if needed)\nconst sheetItems = $('Get All IDs1').all();\nconst existingIds = new Set(\n  sheetItems.map(r => r.json.listing_id).filter(Boolean).map(String)\n);\n\n// Keywords for filtering\nconst blockKeywords = ['block', 'mansion', 'portfolio', 'freehold', 'apartments', 'units', 'entire'];\nconst commercialKeywords = ['commercial', 'office', 'retail', 'warehouse', 'shop', 'business premises', 'storage unit', 'industrial'];\n\n// Filter new listings\nconst newListings = gumtreeData.filter(item => {\n  // Skip if already exists in sheet\n  if (existingIds.has(String(item.listing_id))) return false;\n\n  // Skip if commercial keywords present\n  const text = ((item.title || '') + ' ' + (item.description || '')).toLowerCase();\n  if (commercialKeywords.some(kw => text.includes(kw))) return false;\n\n  return true;\n}).map(item => {\n  // Classify property\n  const text = ((item.title || '') + ' ' + (item.description || '')).toLowerCase();\n  const isBlock = blockKeywords.some(kw => text.includes(kw));\n  return { ...item, classification: isBlock ? 'Block of Apartments' : 'Single Apartment' };\n});\n\nconsole.log('Gumtree scraped:', gumtreeData.length, '| Existing in sheet:', existingIds.size, '| New after dedup:', newListings.length);\n\n// Format for output\nreturn newListings.map(item => ({ json: {\n  listing_id:       String(item.listing_id || ''),\n  listing_url:      String(item.listing_url || ''),\n  title:            String(item.title || ''),\n  price:            String(item.price || ''),\n  price_value:      item.price_value || '',\n  location:         String(item.location || ''),\n  property_type:    item.classification,\n  bedrooms:         String(item.bedrooms || ''),\n  \"Seller Name\":    item['Seller Name'] || '',\n  \"Phone Number\":   '', // you can extract if available\n  \"Date Available\": item['Date Available'] || '',\n  \"Posted Date\":    String(item.scraped_at || ''),\n  description:      item.description || '',\n  \"Image Url\":      String(item.imageUrl || ''),\n  \"Scraped At\":     new Date().toISOString(),\n  \"Status\":         'New',\n  \"Draft Message\":  '',\n  \"Approved\":       'FALSE',\n  \"Sent At\":        '',\n  \"Notes\":          '',\n  \"seller_type\":    (item.features || []).includes('Private') ? 'Private' : 'Agency'\n}}));"
      },
